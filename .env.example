# Database Configuration
DB_HOST=db
DB_USER=syfe_user
DB_PASS=syfe_secure_pass
DB_NAME=syfe_db

# SMTP Configuration (Required for Production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM=noreply@example.com

# Session & Security
SESSION_LIFETIME=24
REQUIRE_LOGIN=true
PASSWORD_STRENGTH=strong
SERVER_PEPPER=8f39b6e2c1a4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0

# Reverse Proxy Configuration
# Set to 'true' if the app is behind a reverse proxy (e.g., Caddy, Nginx)
REVERSE_PROXY=false

# Development/Testing
# Set to 'true' to bypass email verification and log codes to PHP error log
TEST_MODE=true
